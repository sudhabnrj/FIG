# Server Environment Settings (Required)
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/interview_guide
# A secure randomly generated secret (minimum 32 characters long)
JWT_SECRET=placeholder_jwt_secret_value_at_least_32_chars_long
JWT_REFRESH_SECRET=placeholder_jwt_refresh_secret_value_at_least_32_chars_long

# OAuth credentials (optional for local development)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Application settings
APP_URL=http://localhost:3001

# Note: Ensure you define your actual runtime secrets in .env.local (which is git-ignored)
# Example production MongoDB Atlas URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>

